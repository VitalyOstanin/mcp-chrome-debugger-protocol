{
  "name": "@vitalyostanin/mcp-chrome-debugger-protocol",
  "version": "1.3.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": "dist/index.js",
  "bin": {
    "mcp-chrome-debugger-protocol": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "chmod +x dist/index.js",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "dev:server": "npm run build && node dist/index.js",
    "dev:test": "bash scripts/dev-test.sh",
    "dev:test:ts": "bash scripts/dev-test.sh ts",
    "mcp:install": "bash scripts/install-claude-code-mcp.sh",
    "mcp:install:dev": "bash scripts/install-claude-code-dev-mcp.sh",
    "mcp:uninstall": "bash scripts/uninstall-claude-code-mcp.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:watch": "vitest --config vitest.integration.config.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepublishOnly": "npm run build"
  },
  "author": "Vitaly Ostanin <vitaly.ostanin@gmail.com>",
  "license": "MIT",
  "description": "MCP server for Chrome debugger protocol (Node.js)",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "chrome-devtools",
    "debugger",
    "nodejs",
    "debugging",
    "chrome-remote-interface",
    "claude"
  ],
  "homepage": "https://github.com/VitalyOstanin/mcp-chrome-debugger-protocol#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VitalyOstanin/mcp-chrome-debugger-protocol.git"
  },
  "bugs": {
    "url": "https://github.com/VitalyOstanin/mcp-chrome-debugger-protocol/issues"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md"
  ],
  "dependencies": {
    "@jridgewell/trace-mapping": "^0.3.31",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/ws": "^8.18.1",
    "@vscode/debugadapter": "^1.68.0",
    "@vscode/debugprotocol": "^1.68.0",
    "chrome-remote-interface": "^0.34.0",
    "ws": "^8.20.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/chrome-remote-interface": "^0.33.0",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "express": "^5.2.1",
    "get-port": "^7.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  },
  "publishConfig": {
    "access": "public"
  },
  "overrides": {
    "ip-address": "^10.2.0"
  }
}
