{
  "name": "@vitalyostanin/mcp-chrome-debugger-protocol",
  "version": "1.8.0",
  "type": "module",
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "main": "dist/index.js",
  "bin": {
    "mcp-chrome-debugger-protocol": "dist/index.js"
  },
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "tsc -p tsconfig.build.json",
    "postbuild": "chmod +x dist/index.js",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev:server": "npm run build && node dist/index.js",
    "dev:test": "bash scripts/dev-test.sh",
    "test": "NODE_OPTIONS='--max-old-space-size=1024' vitest run",
    "test:watch": "NODE_OPTIONS='--max-old-space-size=1024' vitest",
    "test:coverage": "NODE_OPTIONS='--max-old-space-size=1024' vitest run --coverage",
    "test:integration": "NODE_OPTIONS='--max-old-space-size=2048' timeout 30m vitest run --config vitest.integration.config.ts",
    "test:integration:watch": "NODE_OPTIONS='--max-old-space-size=2048' vitest --config vitest.integration.config.ts",
    "test:all": "npm test && npm run test:integration",
    "bench": "NODE_OPTIONS='--max-old-space-size=1024' vitest bench --run",
    "lint": "eslint . --cache --cache-location node_modules/.cache/eslint/",
    "lint:fix": "eslint . --fix --cache --cache-location node_modules/.cache/eslint/",
    "format": "npm run lint:fix",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run test && npm audit --omit=dev --audit-level=high && npm run build"
  },
  "author": "Vitaly Ostanin <vitaly.ostanin@gmail.com>",
  "license": "MIT",
  "description": "MCP server for Chrome debugger protocol (Node.js)",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "chrome-devtools",
    "debugger",
    "nodejs",
    "debugging",
    "chrome-remote-interface",
    "claude"
  ],
  "homepage": "https://github.com/VitalyOstanin/mcp-chrome-debugger-protocol#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VitalyOstanin/mcp-chrome-debugger-protocol.git"
  },
  "bugs": {
    "url": "https://github.com/VitalyOstanin/mcp-chrome-debugger-protocol/issues"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@jridgewell/trace-mapping": "^0.3.31",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/ws": "^8.18.1",
    "@vscode/debugadapter": "^1.68.0",
    "@vscode/debugprotocol": "^1.68.0",
    "chrome-remote-interface": "^0.34.0",
    "safe-stable-stringify": "^2.5.0",
    "ws": "^8.20.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/chrome-remote-interface": "^0.33.0",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitest/coverage-v8": "^4.1.5",
    "c8": "^11.0.0",
    "eslint": "^10.3.0",
    "express": "^5.2.1",
    "get-port": "^7.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  },
  "publishConfig": {
    "access": "public"
  },
  "overrides": {
    "ip-address": "^10.2.0",
    "hono": "^4.12.21",
    "brace-expansion": "^5.0.6"
  }
}
