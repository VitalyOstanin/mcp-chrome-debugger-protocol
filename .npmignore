# package.json `files` is the source of truth for what ends up in the tarball
# (only dist/**/*.{js,d.ts} + README.md). This .npmignore is a defence-in-depth
# layer that keeps obvious dev artefacts out even if `files` is loosened.

# Demo files (large size)
demo-ts-mcp-chrome-debugger-protocol.gif
demo-ts-mcp-chrome-debugger-protocol.svg

# Development files
src/
tests/
eslint.config.mjs
vitest.config.ts
vitest.integration.config.ts
tsconfig.json
tsconfig.base.json
tsconfig.build.json

# Documentation (keep only README.md)
AGENTS.md
CLAUDE.md
CHANGELOG.md
BUGFIX-source-map-path-normalization.md
DONATIONS.md
docs/
donation-qr.png

# Source maps (development only)
dist/**/*.map

# Development scripts
scripts/

# IDE and system files
.vscode/
.idea/
.editorconfig
.nvmrc
*.log
*.pid
*.tmp
.DS_Store
Thumbs.db

# Git / GitHub
.git/
.gitignore
.github/

# Coverage reports
coverage/
coverage-integration/

# Node modules
node_modules/